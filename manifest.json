{
  "manifest_version": 3,
  "name": "Apollo Lead Agent",
  "version": "6.0",
  "description": "You check the contacts. Agent handles navigation + data extraction + Google Sheets.",
  "permissions": ["storage", "tabs"],
  "host_permissions": [
    "https://app.apollo.io/*",
    "https://script.google.com/*",
    "https://script.googleusercontent.com/*"
  ],
  "background": { "service_worker": "background.js" },
  "content_scripts": [
    {
      "matches": ["https://app.apollo.io/*"],
      "js": ["agent.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": { "48": "icon.png" }
  }
}
